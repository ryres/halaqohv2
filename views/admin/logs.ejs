<div class="card">
  <div class="card-header" style="background:#34495e; color:white;">
    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Audit Log</h5>
  </div>
  <div class="card-body">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger alert-dismissible fade show"><%= error %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    <% } %>

    <div class="table-responsive">
      <table class="table table-hover table-sm">
        <thead style="background:#f8f9fa;">
          <tr>
            <th>No</th>
            <th>User</th>
            <th>Method</th>
            <th>URL / Action</th>
            <th>IP Address</th>
            <th>Timestamp</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach((log, idx) => { %>
            <%
              const actionParts = (log.action || '').split(' ');
              const method = actionParts[0] || '';
              const url = actionParts.slice(1).join(' ') || '-';
            %>
            <tr>
              <td><%= idx + 1 %></td>
              <td><strong><%= log.user_name || log.username || 'System' %></strong></td>
              <td>
                <% if (method === 'POST') { %>
                  <span class="badge bg-info">POST</span>
                <% } else if (method === 'PUT') { %>
                  <span class="badge bg-warning text-dark">PUT</span>
                <% } else if (method === 'DELETE') { %>
                  <span class="badge bg-danger">DELETE</span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= method %></span>
                <% } %>
              </td>
              <td><small class="text-muted"><code><%= url %></code></small></td>
              <td><small><%= log.ip_address || '-' %></small></td>
              <td><small><%= new Date(log.created_at).toLocaleString('id-ID') %></small></td>
            </tr>
          <% }); %>
          <% if (logs.length === 0) { %>
            <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-3 d-block mb-2"></i>Belum ada log aktivitas</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
      <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
          <li class="page-item <% if (currentPage === 1) { %>disabled<% } %>">
            <a class="page-link" href="/logs?page=<%= currentPage - 1 %>">Previous</a>
          </li>
          <% for (let i = 1; i <= Math.min(totalPages, 5); i++) { %>
            <li class="page-item <% if (currentPage === i) { %>active<% } %>">
              <a class="page-link" href="/logs?page=<%= i %>"><%= i %></a>
            </li>
          <% } %>
          <li class="page-item <% if (currentPage === totalPages) { %>disabled<% } %>">
            <a class="page-link" href="/logs?page=<%= currentPage + 1 %>">Next</a>
          </li>
        </ul>
      </nav>
    <% } %>
  </div>
</div>
