<div class="card max-width-600 mx-auto">
  <div class="card-header" style="background:var(--primary); color:white;">
    <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit Halaqoh: <%= halaqoh.nama_halaqoh %></h5>
  </div>
  <div class="card-body">
    <form method="post" action="/halaqoh/<%= halaqoh.id %>">
      <div class="mb-3">
        <label class="form-label fw-semibold">Nama Halaqoh</label>
        <input type="text" name="nama_halaqoh" class="form-control" value="<%= halaqoh.nama_halaqoh %>" required />
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Guru</label>
        <select name="guru_id" class="form-control">
          <option value="">-- Pilih Guru --</option>
          <% gurus.forEach(g => { %>
            <option value="<%= g.id %>" <%= halaqoh.guru_id == g.id ? 'selected' : '' %>><%= g.nama %></option>
          <% }); %>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Ruangan</label>
        <input type="text" name="ruangan" class="form-control" value="<%= halaqoh.ruangan || '' %>" />
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Jadwal</label>
        <input type="text" name="jadwal" class="form-control" value="<%= halaqoh.jadwal || '' %>" placeholder="Contoh: Senin 14:00-16:00" />
      </div>
      
      <hr>
      <div class="d-flex justify-content-end gap-2">
        <a href="/halaqoh" class="btn btn-secondary">Batal</a>
        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Simpan Perubahan</button>
      </div>
    </form>
  </div>
</div>
