<div class="row">
  <div class="col-md-6">
    <div class="card p-4">
      <h5><i class="bi bi-graph-up me-2"></i>Jalankan K-Means Clustering</h5>
      <hr>
      <form id="clusteringForm">
        <div class="mb-3">
          <label class="form-label">Jumlah Cluster (K)</label>
          <input type="number" name="k" class="form-control" value="3" min="2" max="10" required>
          <small class="text-muted">Tentukan jumlah cluster (2-10)</small>
        </div>
        <div class="mb-3">
          <label class="form-label">Max Iterasi</label>
          <input type="number" name="maxIter" class="form-control" value="100" min="10" max="500">
          <small class="text-muted">Maksimal iterasi untuk konvergensi</small>
        </div>
        <div class="mb-3">
          <label class="form-label">Engine Perhitungan</label>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary flex-fill" onclick="selectEngine('javascript')" id="engine-js-btn">JavaScript</button>
            <button type="button" class="btn btn-outline-secondary flex-fill" onclick="selectEngine('python')" id="engine-py-btn">Python</button>
          </div>
          <input type="hidden" name="engine" id="engineInput" value="javascript">
          <small class="text-muted">Pilih JavaScript untuk jalur bawaan, atau Python untuk opsi tambahan.</small>
        </div>
        <button type="button" class="btn btn-primary w-100" onclick="runClustering()">
          <i class="bi bi-play-circle me-2"></i>Jalankan Clustering
        </button>
      </form>
      <div id="clusteringResult" class="mt-4" style="display:none;">
        <div class="alert alert-success" role="alert">
          <h6>Clustering Selesai!</h6>
          <p><strong>Silhouette Score:</strong> <span id="silhouetteScore">-</span></p>
          <p><strong>Total Cluster:</strong> <span id="totalCluster">-</span></p>
          <a href="/result" class="btn btn-sm btn-info">Lihat Hasil</a>
        </div>
      </div>
      <div id="clusteringError" class="mt-4" style="display:none;">
        <div class="alert alert-danger" role="alert" id="errorMsg"></div>
      </div>
      <div id="clusteringLoading" class="mt-4" style="display:none;">
        <div class="spinner-border" role="status">
          <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Processing...</p>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card p-4">
      <h5><i class="bi bi-info-circle me-2"></i>Informasi</h5>
      <hr>
      <p><strong>Algoritma:</strong> K-Means with Manhattan Distance</p>
      <p><strong>Fitur yang digunakan:</strong></p>
      <ul>
        <li>Juz (Target Capaian)</li>
        <li>Tajwid</li>
        <li>Kelancaran</li>
        <li>Makhraj</li>
      </ul>
      <p><strong>Evaluasi:</strong> Silhouette Score (Range: -1 hingga 1)</p>
      <hr>
      <p class="text-muted small">Silhouette Score menunjukkan seberapa baik pemisahan cluster. Nilai mendekati 1 = baik, mendekati 0 = overlapping, mendekati -1 = buruk.</p>
    </div>
  </div>
</div>

<script>
let lastClusteringResult = null;

function selectEngine(engine) {
  const input = document.getElementById('engineInput');
  const jsBtn = document.getElementById('engine-js-btn');
  const pyBtn = document.getElementById('engine-py-btn');

  input.value = engine;
  if (engine === 'python') {
    pyBtn.className = 'btn btn-primary flex-fill';
    jsBtn.className = 'btn btn-outline-primary flex-fill';
  } else {
    jsBtn.className = 'btn btn-primary flex-fill';
    pyBtn.className = 'btn btn-outline-secondary flex-fill';
  }
}

async function runClustering() {
  const k = document.querySelector('input[name="k"]').value;
  const maxIter = document.querySelector('input[name="maxIter"]').value;
  const engine = document.getElementById('engineInput').value;

  document.getElementById('clusteringLoading').style.display = 'block';
  document.getElementById('clusteringResult').style.display = 'none';
  document.getElementById('clusteringError').style.display = 'none';

  try {
    const res = await fetch('/api/clustering/process', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ k: parseInt(k), maxIter: parseInt(maxIter), engine })
    });

    const data = await res.json();
    if (data.error) throw new Error(data.error);

    lastClusteringResult = data;
    document.getElementById('silhouetteScore').innerText = data.silhouette.toFixed(4);
    document.getElementById('totalCluster').innerText = Object.keys(data.clusters || {}).length;
    document.getElementById('clusteringResult').style.display = 'block';
    
    // Store result in sessionStorage for result page
    sessionStorage.setItem('clusteringResult', JSON.stringify(data));
  } catch (err) {
    document.getElementById('errorMsg').innerText = err.message;
    document.getElementById('clusteringError').style.display = 'block';
  } finally {
    document.getElementById('clusteringLoading').style.display = 'none';
  }
}
</script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  selectEngine('javascript');
});
</script>
